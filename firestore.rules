rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: groups
    // Document ID: {groupId} (Group Code)
    // Fields:
    //   - id: string (required) - Group code
    //   - name: string (required) - Group name
    //   - adminUid: string (required) - Creator UID
    //   - members: map (required) - Map of UID to GroupMember
    //
    // GroupMember:
    //   - uid: string
    //   - name: string
    //   - latitude: number
    //   - longitude: number
    //   - lastUpdated: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isGroupAdmin(groupId) {
      return isAuthenticated() && resource.data.adminUid == request.auth.uid;
    }

    function isMember(groupId) {
      return isAuthenticated() && request.auth.uid in resource.data.members;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['id', 'name', 'adminUid', 'members']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.adminUid is string &&
             data.members is map;
    }

    function isValidMemberUpdate(groupId) {
      // Allow update if only the current user's member entry is changing
      // and only latitude, longitude, lastUpdated are updated
      let oldMembers = resource.data.members;
      let newMembers = request.resource.data.members;
      let uid = request.auth.uid;
      
      return newMembers.keys().hasAll(oldMembers.keys()) &&
             newMembers[uid].uid == uid &&
             newMembers[uid].name == oldMembers[uid].name &&
             newMembers[uid].latitude is number &&
             newMembers[uid].longitude is number &&
             newMembers[uid].lastUpdated is int;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /groups/{groupId} {
      // Anyone authenticated can create a group
      allow create: if isAuthenticated() && isValidGroup(request.resource.data) && 
                      request.resource.data.adminUid == request.auth.uid;
      
      // Members can read the group
      allow read: if isMember(groupId);
      
      // Members can join (update members map) or update their location
      allow update: if isAuthenticated() && (
        // Case 1: Joining the group
        (!isMember(groupId) && request.resource.data.members.keys().hasAll(resource.data.members.keys()) && request.auth.uid in request.resource.data.members) ||
        // Case 2: Updating own location
        (isMember(groupId) && isValidMemberUpdate(groupId)) ||
        // Case 3: Admin updating group info
        isGroupAdmin(groupId)
      ) && isValidGroup(request.resource.data);

      allow delete: if isGroupAdmin(groupId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
